# ─────────────────────────────────────────────────────────────────────────────
# Multi-Mode AI Middleware — Environment Variables Template
# Copy this to .env and fill in your values. Never commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────
GEMINI_API_KEY=               # https://aistudio.google.com/app/apikey
JWT_SECRET=                   # python -c "import secrets; print(secrets.token_hex(32))"
FERNET_KEY=                   # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── LLM Model (optional) ──────────────────────────────────────
LITELLM_MODEL=gemini-2.0-flash

# ── Redis — Semantic Cache (optional, falls back to in-memory) ─
REDIS_URL=redis://localhost:6379

# ── MongoDB — Audit Logs (optional, falls back to in-memory) ──
MONGODB_URI=
MONGODB_DB_NAME=ai_middleware_db

# ── Google Classroom (optional — simulated data without these) ─
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ── App Server ─────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
